# ========== Бэкенд ==========
# Виртуальное окружение
backend/venv/
backend/env/
backend/.venv/
.env
# Кэш Python
backend/__pycache__/
backend/*/__pycache__/
*.py[cod]
*.pyo

# Миграции (сами файлы нужны, но .pyc не нужны)
backend/alembic/versions/*.pyc

# Конфиги с секретами
backend/.env
backend/.env.*

# Логи
*.log
backend/logs/

# ========== Фронтенд ==========
# Node.js
frontend/node_modules/
frontend/.npm/
frontend/.yarn/

# Сборка
frontend/dist/
frontend/build/
frontend/.next/
frontend/out/

# Конфиги с секретами
frontend/.env
frontend/.env.*
frontend/.env.local

# Логи npm/yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ========== Общее ==========
# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Временные файлы
*.tmp
*.temp
*.bak
*~

# Тесты (если будут)
.pytest_cache/
.coverage
htmlcov/
.tox/